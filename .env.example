# Instagram Graph API — https://developers.facebook.com/docs/instagram-api/
# Requires an Instagram Business account connected to a Facebook Page.
# Get your token from: Meta for Developers → Graph API Explorer
# Required scope: instagram_content_publish

INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_USER_ID=your_instagram_business_user_id_here

# Image hosting (imgBB) — https://api.imgbb.com/
# Required for instagram-publisher skill. Get a free API key at https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here

# ── Video Pipeline ────────────────────────────────────────────────────────────
# TTS: edge-tts (padrão, gratuito, online) | kokoro (local, 82M params) | piper (CPU leve)
LOCAL_TTS_MODEL=edge-tts
LOCAL_TTS_VOICE=pt-BR-FranciscaNeural

# Geração de imagem local: diffusers (padrão, MPS no M1) | auto1111 | comfyui
LOCAL_IMAGE_PROVIDER=diffusers
LOCAL_IMAGE_MODEL=stabilityai/sdxl-turbo

# Transcrição Whisper: tiny | base (padrão) | small — NUNCA large em 8GB RAM
WHISPER_MODEL_SIZE=base

# Ollama (opcional, para análise de imagem): ollama pull llava
OLLAMA_MODEL=llava

# ── APIs Externas ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
BLOTATO_API_KEY=your_blotato_api_key_here
APIFY_API_KEY=your_apify_api_key_here
